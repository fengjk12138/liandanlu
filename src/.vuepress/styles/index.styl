.sidebar .sidebar-heading {
  font-size: 20px;
  font-weight: bold;
  background-color: #e3f2fd; // 浅蓝色背景
  padding: 10px;
  border-left: 4px solid #2196f3; // 蓝色左边框
  margin-bottom: 5px;
  border-radius: 4px; // 添加圆角
}

.sidebar .sidebar-item {
  font-size: 16px;
  padding: 5px 10px;
  margin-left: 20px;
  color: #555; // 更深的文本颜色
}
